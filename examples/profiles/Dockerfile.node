FROM node:22-bookworm-slim

ARG OPENCODE_VERSION=latest

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        curl \
        unzip \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install opencode.
RUN curl -fsSL https://opencode.ai/install | bash
ENV PATH="/root/.local/bin:$PATH"

EXPOSE 4096
WORKDIR /workspace
